# Copy this file to .env and fill in your values

# MongoDB Atlas connection string
# Go to MongoDB Atlas > Clusters > Connect > Connect your application
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/elearning_db?retryWrites=true&w=majority

# Server port
PORT=5000

# Environment
NODE_ENV=development

# JWT secret - use a long random string in production
JWT_SECRET=replace_this_with_a_long_random_secret_string

# JWT expiry
JWT_EXPIRE=7d

# Frontend URL (for CORS)
CLIENT_URL=http://localhost:3000

# Email (optional - only needed for forgot password feature)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
