{
  "name": "webtech-elearning-platform",
  "version": "1.0.0",
  "description": "A comprehensive MERN stack e-learning platform with 20+ dynamic pages",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "client": "cd client && npm start",
    "server": "nodemon server.js",
    "dev:full": "concurrently \"npm run dev\" \"npm run client\"",
    "build": "cd client && npm run build"
  },
  "keywords": [
    "e-learning",
    "MERN",
    "education",
    "courses",
    "online-learning"
  ],
  "author": "myapps123",
  "license": "ISC",
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.0.3",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.0",
    "mongoose": "^7.0.0",
    "multer": "^1.4.5-lts.1",
    "validator": "^13.9.0"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "nodemon": "^2.0.22"
  }
}
